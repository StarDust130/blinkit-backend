{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "types": ["node"] // ⬅️ 1. Force it to load Node types globally
  },
  "include": [
    "src/**/*",
    "prisma.config.ts" // ⬅️ 2. Force it to read the root config file
  ],
  "exclude": ["node_modules"]
}
