{
  "compilerOptions": {
    // 🚀 Output modern JavaScript
    "target": "ES2022",

    // 📦 Use modern Node.js ESM system
    "module": "nodenext",

    // 📂 Source code folder
    "rootDir": "./src",

    // 🏗️ Compiled JS output folder
    "outDir": "./dist",

    // 🛡️ Strong TypeScript safety checks
    "strict": true,

    // 🔄 Helps old CommonJS packages work with import/export
    "esModuleInterop": true,

    // ⚡ Skip checking library types for faster builds
    "skipLibCheck": true,

    // 🖥️ Prevent Windows/Linux filename case bugs
    "forceConsistentCasingInFileNames": true,

    // 📍 Base path for cleaner imports
    "baseUrl": "./src",

    // ✨ Custom path alias
    // Example:
    // import x from "@/utils/test.js"
    "paths": {
      "@/*": ["*"]
    },

    // 🔕 Hide TypeScript 6 deprecation warning
    "ignoreDeprecations": "6.0"
  },

  // 📂 Only compile files inside src
  "include": ["src"]
}

