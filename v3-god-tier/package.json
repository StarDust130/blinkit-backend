{
  "name": "v3-god-tier",
  "version": "1.0.0",
  "description": "🚀 Production-grade backend built with TypeScript, Express, Prisma, Redis, and RabbitMQ.",
  "keywords": [
    "backend",
    "typescript",
    "express",
    "prisma",
    "redis"
  ],
  "author": "Thor ⚡",
  "license": "MIT",
  "main": "index.js",
  "type": "module",
  "private": true,
  "scripts": {
  "dev": "nodemon --watch src --exec tsx src/server.ts",
  "build": "tsc",
  "start": "node dist/server.js",
  "worker": "tsx src/workers/order.worker.ts",
  "db:generate": "prisma generate",
  "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "amqplib": "^1.0.6",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "morgan": "^1.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.2",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
