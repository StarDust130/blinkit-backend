{
  "name": "v3-god-tier",
  "version": "1.0.0",
  "description": "🚀 Advanced production-grade backend architecture built with TypeScript, Express, Prisma, Redis, and RabbitMQ. Designed for scalable APIs, event-driven workflows, caching, workers, and enterprise-level backend systems.",
  "keywords": [
    "backend",
    "microservices",
    "typescript",
    "nodejs",
    "express",
    "prisma",
    "postgresql",
    "redis",
    "rabbitmq",
    "api",
    "scalable",
    "production-ready",
    "worker",
    "event-driven",
    "security",
    "high-performance",
    "docker",
    "saas",
    "enterprise"
  ],
  "author": "Thor ⚡",
  "license": "MIT",
  "main": "index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec tsx src/server.ts",
    "worker": "tsx src/workers/order.worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev:watch": "nodemon --watch src --exec tsx src/server.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "amqplib": "^1.0.6",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "morgan": "^1.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
